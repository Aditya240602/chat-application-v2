# Copy this file to .env and fill in real values. Never commit the actual .env file.

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
BACKEND_BASE_URL=http://localhost:8000

# PostgreSQL connection (matches what you set up in pgAdmin)
POSTGRES_DB=chat_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-postgres-superuser-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Required by POST /api/register/ -- clients must send this value as "secret"
# in the registration request body, or registration is rejected.
REGISTRATION_SECRET=replace-with-a-secret-registration-code
